{
  "name": "codenuke",
  "version": "0.4.0",
  "private": false,
  "description": "Autonomous behavior-preserving code reduction.",
  "license": "MIT",
  "bin": {
    "codenuke": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "scripts",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "scripts": {
    "build": "node scripts/bundle-cli.mjs",
    "codenuke": "node dist/cli.cjs",
    "codenuke:build": "pnpm -s build && node dist/cli.cjs",
    "prepack": "pnpm -s build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
