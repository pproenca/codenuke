{
  "name": "@codenuke/scorer",
  "version": "0.1.0",
  "private": true,
  "description": "The immutable judge's keep/revert decision (gates + value) — modernized pure core of loop/scorer.mjs.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/scorer.d.ts",
