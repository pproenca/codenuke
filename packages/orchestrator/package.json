{
  "name": "@codenuke/orchestrator",
  "version": "0.1.0",
  "description": "Orchestration-layer pure logic: region/move selection, doctor readiness, command dispatch — modernized from autoloop/doctor/bin.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/orchestrator.d.ts",
      "import": "./dist/orchestrator.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm -s clean && tsc -p tsconfig.build.json",
    "prepack": "pnpm -s build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codenuke/artifacts": "workspace:*",
    "@codenuke/calibrate": "workspace:*",
    "@codenuke/changecost": "workspace:*",
    "@codenuke/config": "workspace:*",
    "@codenuke/exec": "workspace:*",
    "@codenuke/fence": "workspace:*",
    "@codenuke/measure": "workspace:*",
    "@codenuke/scorer": "workspace:*",
    "@codenuke/substrate": "workspace:*",
    "@codenuke/value-proxy": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@types/node": "^22.0.0"
  },
  "private": true
}
