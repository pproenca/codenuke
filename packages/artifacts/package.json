{
  "name": "@codenuke/artifacts",
  "version": "0.1.0",
  "private": true,
  "description": "Safety-artifact validity + freshness gates (fence/calibration/value-proxy) for codenuke — modernized slice of loop/artifacts.mjs.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/artifacts.d.ts",
      "import": "./dist/artifacts.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm -s build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codenuke/exec": "workspace:*",
    "@codenuke/guards": "workspace:*",
    "@codenuke/json": "workspace:*",
    "@codenuke/stats": "workspace:*",
    "@codenuke/value-proxy": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22"
  }
}
