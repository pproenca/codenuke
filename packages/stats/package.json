{
  "name": "@codenuke/stats",
  "version": "0.1.0",
  "private": true,
  "description": "Statistical primitives for codenuke safety gates (modernized slice of loop/stats.mjs).",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/stats.d.ts",
      "import": "./dist/stats.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm -s build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.build.json"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22"
  }
}
