{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src/main",
    "paths": {
      "@codenuke/artifacts": ["../artifacts/dist/artifacts.d.ts"],
      "@codenuke/calibrate": ["../calibrate/dist/calibrate.d.ts"],
      "@codenuke/changecost": ["../changecost/dist/changecost.d.ts"],
      "@codenuke/config": ["../config/dist/config.d.ts"],
      "@codenuke/exec": ["../exec/dist/exec.d.ts"],
      "@codenuke/fence/runtime": ["../fence/dist/runtime.d.ts"],
      "@codenuke/measure": ["../measure/dist/measure.d.ts"],
      "@codenuke/scorer": ["../scorer/dist/scorer.d.ts"],
      "@codenuke/substrate": ["../substrate/dist/index.d.ts"],
      "@codenuke/value-proxy": ["../value-proxy/dist/value-proxy.d.ts"]
