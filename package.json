{
  "name": "codenuke",
  "version": "0.4.0",
  "description": "Autonomous behavior-preserving code reduction.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "codenuke": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "codenuke": "node dist/cli.cjs",
    "codenuke:build": "pnpm -s build && node dist/cli.cjs",
    "test": "vitest run",
    "typecheck": "pnpm -r --filter './*' run typecheck",
    "build": "pnpm -r --filter './*' --if-present run build && node scripts/bundle-cli.mjs",
    "prepack": "pnpm -s build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
