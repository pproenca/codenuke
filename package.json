{
  "name": "codenuke",
  "version": "0.3.0",
  "description": "Autonomous behavior-preserving code reduction: an immutable metric drives a propose → score → keep/revert loop (Karpathy's autoresearch, applied to refactoring).",
  "license": "MIT",
  "bin": {
    "codenuke": "bin/codenuke.mjs"
  },
  "files": [
    "loop",
    "bin",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "node scripts/check-js-syntax.mjs",
    "prepack": "pnpm -s build",
    "typecheck": "pnpm -s build",
    "lint": "oxlint . --config oxlint.json",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "loop:fence": "node bin/codenuke.mjs fence",
    "loop:run": "node bin/codenuke.mjs run",
    "eval": "node evals/scripts/run-loop.mjs",
    "benchmark-add": "node evals/scripts/benchmark-add.mjs",
    "validate-substrates": "node evals/scripts/validate-substrates.mjs",
    "pack:smoke": "node scripts/package-smoke.mjs"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "oxfmt": "^0.50.0",
    "oxlint": "^1.64.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.2"
}
