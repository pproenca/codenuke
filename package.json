{
  "name": "codenuke",
  "version": "0.3.0",
  "description": "Automated code review for reliable, trusted refactoring.",
  "license": "MIT",
  "bin": {
    "codenuke": "dist/cli.js"
  },
  "files": [
    "dist",
    "resources",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "prepack": "pnpm -s build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint . --config oxlint.json",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "eval": "pnpm -s build && node evals/scripts/run-all.mjs && node evals/scripts/run-semantic-roi.mjs",
    "pack:smoke": "node scripts/package-smoke.mjs"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.64.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.2"
}
