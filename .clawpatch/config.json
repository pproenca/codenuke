{
  "schemaVersion": 1,
  "stateDir": ".clawpatch",
  "include": [
    "**/*"
  ],
  "exclude": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "target/**",
    ".build/**",
    ".git/**",
    ".clawpatch/**"
  ],
  "provider": {
    "name": "codex",
    "model": null,
    "reasoningEffort": null
  },
  "commands": {
    "typecheck": "pnpm typecheck",
    "lint": null,
    "format": null,
    "test": "pnpm test"
  },
  "review": {
    "maxContextFiles": 24,
    "maxOwnedFiles": 12,
    "maxFindingsPerFeature": 10,
    "minConfidenceToFix": "medium"
  },
  "git": {
    "requireCleanWorktreeForFix": false,
    "commit": false,
    "openPr": false
  }
}
